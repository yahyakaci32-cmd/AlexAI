// دالة نسخ الكود
function copyCode(btn) {
    const code = btn.nextElementSibling.querySelector('code').innerText; // تعديل بسيط لضمان اختيار الكود الصحيح
    navigator.clipboard.writeText(code).then(() => {
        btn.innerText = "تم النسخ! ✅";
        btn.style.background = "#64ffda";
        btn.style.color = "#000";
        setTimeout(() => {
            btn.innerText = "نسخ الكود 📋";
            btn.style.background = "rgba(255, 255, 255, 0.1)";
            btn.style.color = "#fff";
        }, 2000);
    });
}

// دالة قراءة النص بصوت
function speakText(btn) {
    const textToSpeak = btn.nextElementSibling.innerText; // النص بعد زر الصوت
    const utterance = new SpeechSynthesisUtterance(textToSpeak);
    // يمكنك تعديل اللغة أو الصوت هنا
    utterance.lang = 'ar-SA'; // للغة العربية السعودية
    // utterance.voice = window.speechSynthesis.getVoices().find(voice => voice.lang === 'ar-SA'); // اختيار صوت معين
    window.speechSynthesis.speak(utterance);
}

// دالة تحميل الصورة
function downloadImage(imageUrl) {
    const link = document.createElement('a');
    link.href = imageUrl;
    link.download = `Alex_Image_${Date.now()}.png`; // اسم الملف
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
}

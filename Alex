function setMode(mode) {
    currentMode = mode;
    document.querySelectorAll('.mode-selector button').forEach(btn => btn.classList.remove('active-mode'));
    document.getElementById(`btn-${mode}`).classList.add('active-mode');
    
    const imageOptionsDiv = document.getElementById('image-options');
    if (mode === 'image') {
        imageOptionsDiv.style.display = 'flex';
        document.getElementById('user-input').placeholder = "صف الصورة التي تريدها لـ Alex يرسمها (FLUX)...";
    } else {
        imageOptionsDiv.style.display = 'none';
        document.getElementById('user-input').placeholder = "تحدث مع Alex أو اطلب كود برمجي...";
    }
}

async function sendMessage() {
    const input = document.getElementById('user-input');
    const indicator = document.getElementById('typing-indicator');
    if (!input.value.trim()) return;

    const prompt = input.value;
    appendMessage('user', prompt, true); // حفظ رسالة المستخدم
    input.value = '';
    indicator.style.display = 'block';

    if (currentMode === 'image') {
        const seed = Math.floor(Math.random() * 1000000);
        const imgSize = document.getElementById('img-size').value.split('x');
        const imgWidth = imgSize[0];
        const imgHeight = imgSize[1];
        const imgStyle = document.getElementById('img-style').value;
        const imgQuality = document.getElementById('img-quality').value === 'high' ? '&quality=high' : '';

        let fullPrompt = prompt;
        if (imgStyle) {
            fullPrompt = `${imgStyle}, ${prompt}`;
        }

        const imageUrl = `https://pollinations.ai/p/${encodeURIComponent(fullPrompt)}?width=${imgWidth}&height=${imgHeight}&model=flux&seed=${seed}${imgQuality}`;
        
        const img = new Image();
        img.src = imageUrl;
        img.onload = () => {
            appendImage(imageUrl, true); // حفظ الصورة
            indicator.style.display = 'none';
        };
        img.onerror = () => {
            appendMessage('ai', "عذراً، فشل Alex في توليد الصورة. هل يمكنك وصفها بطريقة أخرى؟ 😔", true);
            indicator.style.display = 'none';
        };
    } else {
        try {
            const response = await fetch('/chat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ prompt: prompt })
            });
            const data = await response.json();
            appendMessage('ai', data.reply, true); // حفظ رد Alex
        } catch (error) {
            appendMessage('ai', "آسف يا صديقي، حدث خطأ في الاتصال! 😅", true);
        }
        indicator.style.display = 'none';
    }
}

// دالة إرسال الرسائل (تم تعديلها لدعم زر الصوت وحفظ التاريخ)
function appendMessage(role, text, save = true) {
    const history = document.getElementById('chat-history');
    const div = document.createElement('div');
    div.className = `message ${role}-message`;
    div.style.direction = "auto";
    const name = role === 'ai' ? 'Alex ✨' : 'أنت';
    
    let htmlContent = marked.parse(text);
    
    if (role === 'ai') {
        // إضافة زر الصوت
        htmlContent = `<button class="speak-btn" onclick="speakText(this)">🔊</button>` + htmlContent;

        // إضافة زر النسخ للأكواد
        htmlContent = htmlContent.replace(/<pre><code/g, 
            `<div class="code-container"><button class="copy-btn" onclick="copyCode(this)">نسخ الكود 📋</button><pre><code`);
        htmlContent = htmlContent.replace(/<\/code><\/pre>/g, `</code></pre></div>`);
    }

    div.innerHTML = `<small style="display:block; opacity:0.5; margin-bottom:5px;">${name}</small>` + htmlContent;
    history.appendChild(div);
    history.scrollTop = history.scrollHeight;

    if (save) {
        chatHistory.push({ role: role, type: 'text', content: text });
        localStorage.setItem('alexChatHistory', JSON.stringify(chatHistory));
    }
}

// دالة إضافة الصور (تم تعديلها لدعم زر التحميل وحفظ التاريخ)
function appendImage(url, save = true) {
    const history = document.getElementById('chat-history');
    const div = document.createElement('div');
    div.className = `message ai-message`;
    div.innerHTML = `<small style="display:block; opacity:0.5; margin-bottom:5px;">Alex (الفنان) 🎨</small>
                     <p>تفضل! هذه الصورة تم إنشاؤها بمحرك FLUX المتطور: 🚀</p>
                     <img src="${url}" style="width:100%; border-radius:15px; margin-top:10px; cursor:zoom-in;" onclick="window.open('${url}')">
                     <button class="download-img-btn" onclick="downloadImage('${url}')">تحميل الصورة 💾</button>`;
    history.appendChild(div);
    history.scrollTop = history.scrollHeight;

    if (save) {
        chatHistory.push({ role: 'ai', type: 'image', content: url });
        localStorage.setItem('alexChatHistory', JSON.stringify(chatHistory));
    }
}


